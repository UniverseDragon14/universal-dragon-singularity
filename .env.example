# Copy this file to .env on your private machine/Pi5.
# Never commit the real .env file.

GROQ_API_KEY=put_your_private_groq_key_here
GROQ_MODEL=openai/gpt-oss-120b
PORT=8787

# Private PIN for browser/client calls to your Pi5 backend.
# Use a strong private value. Do not put this in GitHub Pages.
UD_API_PIN=change_this_private_pin

# Browser origins allowed to call the private backend.
ALLOWED_ORIGINS=https://universedragon14.github.io,http://localhost:5173,http://127.0.0.1:5173

# Simple safety limit for backend requests.
RATE_LIMIT_PER_MINUTE=20
